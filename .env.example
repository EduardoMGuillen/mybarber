# App (producción: https://mibarberia.xyz)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Neon)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Auth
AUTH_SECRET=generate-a-long-random-string-here

# Google OAuth (optional for dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Superadmin seed (npm run db:seed)
SUPERADMIN_EMAIL=superadmin@mibarberia.xyz
SUPERADMIN_PASSWORD=change-me-in-production
SUPERADMIN_EMAILS=superadmin@mibarberia.xyz

# Resend — ver dominio en https://resend.com/domains (mibarberia.xyz)
RESEND_API_KEY=
RESEND_FROM_EMAIL=MiBarbería <noreply@mibarberia.xyz>

# PayPal (Sprint 7)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_PLAN_ID=
PAYPAL_MODE=sandbox

# Storage (Vercel → Storage → Blob → Connect to project)
BLOB_READ_WRITE_TOKEN=

# Cron
CRON_SECRET=

# Geocoding uses OpenStreetMap (Nominatim) — no API key required
# Optional: custom User-Agent for Nominatim policy compliance
# GEOCODE_USER_AGENT=MiBarberia/1.0 (contact: you@example.com)

# Rate limit (production, optional)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Web Push (Sprint 9)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@mibarberia.xyz
